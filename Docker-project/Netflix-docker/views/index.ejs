    </header>

    <div class="row">
        <h2>Trending Now</h2>
        <div class="posters">
            <div class="poster-placeholder"></div>
            <div class="poster-placeholder"></div>
            <div class="poster-placeholder"></div>
            <div class="poster-placeholder"></div>
        </div>
    </div>
